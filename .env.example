# abdur.ai — environment variables
# Copy to .env.local and fill. Add to Vercel for production.

# ============== EMAIL (Resend) ==============
RESEND_API_KEY=
RESEND_AUDIENCE_TLDR=
RESEND_AUDIENCE_ASEC=
RESEND_AUDIENCE_MNEMIX=

# ============== AGENT WEBHOOKS ==============
# Generate with: openssl rand -hex 32
AGENT_TOKEN=

# ============== SUPABASE (Phase 2) ==============
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============== STRIPE (Phase 3, Library) ==============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============== ANALYTICS ==============
# Plausible or Vercel Analytics — pick one
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=abdur.ai
